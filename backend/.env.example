PORT=3001
NODE_ENV=development

# Supabase — WAJIB service role key, jangan pakai anon key di backend
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# AES-256-GCM untuk enkripsi token di admin_otp_sessions
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
OTP_ENCRYPTION_KEY=<64-char hex string>

# WhatsApp
WHATSAPP_PROVIDER=fonnte
FONNTE_TOKEN=xxxx

# Rate limiting (in-memory — upgrade ke Redis saat scale >1 instance)
LOGIN_MAX_ATTEMPTS=5
LOGIN_LOCKOUT_MINUTES=15

# OTP
OTP_EXPIRY_MINUTES=5

# CORS
FRONTEND_URL=http://localhost:5173
