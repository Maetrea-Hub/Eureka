PORT=3001
NODE_ENV=development

# Supabase — WAJIB service role key, jangan pakai anon key di backend
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# AES-256-GCM untuk enkripsi token di admin_otp_sessions
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
OTP_ENCRYPTION_KEY=<64-char hex string>

# WhatsApp
WHATSAPP_PROVIDER=fonnte
FONNTE_TOKEN=xxxx

# Rate limiting (in-memory — upgrade ke Redis saat scale >1 instance)
LOGIN_MAX_ATTEMPTS=5
LOGIN_LOCKOUT_MINUTES=15

# OTP
OTP_EXPIRY_MINUTES=5

# Zoom Server-to-Server OAuth — buat di marketplace.zoom.us
# App type: Server-to-Server OAuth, scopes: meeting:write:admin
ZOOM_ACCOUNT_ID=xxxx
ZOOM_CLIENT_ID=xxxx
ZOOM_CLIENT_SECRET=xxxx

# Midtrans — buat di dashboard.midtrans.com → Settings → Access Keys
# Gunakan Sandbox keys untuk development
MIDTRANS_SERVER_KEY=SB-Mid-server-xxxx
MIDTRANS_CLIENT_KEY=SB-Mid-client-xxxx
MIDTRANS_IS_PRODUCTION=false

# CORS
FRONTEND_URL=http://localhost:5173
